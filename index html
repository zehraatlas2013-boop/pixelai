<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>PixelAI Search</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0b0d12;
      color: white;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .box {
      width: 360px;
      text-align: center;
      padding: 20px;
    }

    input {
      width: 100%;
      padding: 12px;
      border-radius: 8px;
      border: none;
      margin-top: 10px;
      box-sizing: border-box;
      display: block;
    }

    button {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
      border: none;
      background: #5a7cff;
      color: white;
      border-radius: 8px;
      cursor: pointer;
      display: block;
      font-weight: bold;
    }

    button:hover {
      background: #3f63ff;
    }

    #out {
      margin-top: 20px;
      background: #1a1d27;
      padding: 12px;
      min-height: 120px;
      border-radius: 8px;
      white-space: pre-wrap;
      text-align: left;
      font-size: 14px;
      line-height: 1.5;
    }
  </style>
</head>
<body>

<div class="box">
  <h2>PixelAI Search 🤖</h2>

  <input id="q" placeholder="Ne öğrenmek istiyorsun?">
  <button onclick="ask()">Ara</button>

  <div id="out">İstediğin her şeyi sorabilirsin...</div>
</div>

<script>
async function ask() {
  const q = document.getElementById("q").value.trim();
  const out = document.getElementById("out");

  if (!q) {
    out.innerText = "Lütfen boş bırakma, bir şeyler yaz! ✍️";
    return;
  }

  out.innerText = "AI düşünüyor... 🤖";

  try {
    out.innerText = await gemini(q);
  } catch (error) {
    out.innerText = "Beklenmedik bir hata oluştu ⚠️";
  }
}

async function gemini(text) {
  // DIKKAT: API anahtarını buraya yazmak sadece yerel (local) denemeler içindir!
  const API_KEY = "GEMINI_API_KEY_BURAYA"; 

  try {
    const res = await fetch(
      "https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=" + API_KEY,
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          contents: [
            {
              parts: [{
                text: "Sen bir arama motoru gibi davran. Kısa, net ve bilgi verici cevaplar ver.\n\nSoru: " + text
              }]
            }
          ]
        })
      }
    );

    const data = await res.json();

    // Gelen veri yapısı kontrolü ve hata yönetimi
    if (data.candidates && data.candidates[0]?.content?.parts?.[0]?.text) {
      return data.candidates[0].content.parts[0].text;
    } else if (data.error) {
      return "API Hatası: " + data.error.message;
    }
    
    return "Cevap yapısı çözülemedi.";

  } catch (e) {
    console.error(e);
    return "AI çalışmadı veya bağlantı reddedildi ⚠️";
  }
}
</script>

</body>
</html>
